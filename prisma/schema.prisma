generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model CapexWeb {
  plano         String?         @db.VarChar(10)
  capex         String          @id @db.VarChar(50)
  jan_ano       Decimal?        @db.Decimal(18, 2)
  fev_ano       Decimal?        @db.Decimal(18, 2)
  mar_ano       Decimal?        @db.Decimal(18, 2)
  abr_ano       Decimal?        @db.Decimal(18, 2)
  mai_ano       Decimal?        @db.Decimal(18, 2)
  jun_ano       Decimal?        @db.Decimal(18, 2)
  jul_ano       Decimal?        @db.Decimal(18, 2)
  ago_ano       Decimal?        @db.Decimal(18, 2)
  set_ano       Decimal?        @db.Decimal(18, 2)
  out_ano       Decimal?        @db.Decimal(18, 2)
  nov_ano       Decimal?        @db.Decimal(18, 2)
  dez_ano       Decimal?        @db.Decimal(18, 2)
  ordem         Int             @default(0)
  meta          Decimal?        @db.Decimal(18, 2)
  status_capex  CapexStatus     @default(PENDENTE)
  status_fisico PhysicalStatus  @default(PENDENTE)
  physicalinput physicalinput[]
  transfersFrom Transfer[]      @relation("TransfersFrom")
  transfersTo   Transfer[]      @relation("TransfersTo")

  @@map("capex_web")
}

model Transfer {
  id        Int      @id @default(autoincrement())
  amount    Decimal  @db.Decimal(18, 2)
  fromCapex String   @db.VarChar(50)
  toCapex   String   @db.VarChar(50)
  from      CapexWeb @relation("TransfersFrom", fields: [fromCapex], references: [capex], onDelete: Cascade)
  to        CapexWeb @relation("TransfersTo", fields: [toCapex], references: [capex], onDelete: Cascade)

  @@index([fromCapex])
  @@index([toCapex])
  @@map("transfers")
}

model Carimbo {
  id           Int                   @id @default(autoincrement())
  nome         String                @unique @db.VarChar(100)
  ativo        Boolean               @default(true)
  ordem        Int                   @default(0)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  solicitacoes SolicitacaoRecursos[]

  @@map("carimbos")
}

model SolicitacaoRecursos {
  id                 String            @id @default(cuid())
  createdAt          DateTime          @default(now())
  plano_investimento String
  valor_aporte       Decimal           @db.Decimal(18, 2)
  desc_fisico        String
  justificativa      String
  email_solicitante  String
  jan                Decimal           @default(0.00) @db.Decimal(18, 2)
  fev                Decimal           @default(0.00) @db.Decimal(18, 2)
  mar                Decimal           @default(0.00) @db.Decimal(18, 2)
  abr                Decimal           @default(0.00) @db.Decimal(18, 2)
  mai                Decimal           @default(0.00) @db.Decimal(18, 2)
  jun                Decimal           @default(0.00) @db.Decimal(18, 2)
  jul                Decimal           @default(0.00) @db.Decimal(18, 2)
  ago                Decimal           @default(0.00) @db.Decimal(18, 2)
  set                Decimal           @default(0.00) @db.Decimal(18, 2)
  out                Decimal           @default(0.00) @db.Decimal(18, 2)
  nov                Decimal           @default(0.00) @db.Decimal(18, 2)
  dez                Decimal           @default(0.00) @db.Decimal(18, 2)
  status_solicitacao StatusSolicitacao @default(pendente)
  decidedAt          DateTime?         @db.DateTime(0)
  decidedByEmail     String?
  carimboid          Int?
  carimbo            Carimbo?          @relation(fields: [carimboid], references: [id])

  @@index([status_solicitacao])
  @@index([carimboid])
  @@map("solicitacao_recursos")
}

model CapexPermission {
  id         String   @id @default(cuid())
  userId     String
  capexLabel String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, capexLabel])
  @@map("capexpermission")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  createdAt DateTime  @default(now())
  usedAt    DateTime?
  expiresAt DateTime
  tokenHash String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId])
  @@map("passwordresettoken")
}

model PermissionRequest {
  id              String                  @id @default(cuid())
  userId          String
  capexLabel      String
  reason          String?
  status          PermissionRequestStatus @default(PENDING)
  createdAt       DateTime                @default(now())
  decidedAt       DateTime?
  decidedByUserId String?
  decidedBy       User?                   @relation("RequestsDecided", fields: [decidedByUserId], references: [id])
  requester       User                    @relation("RequestsMade", fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([decidedByUserId])
  @@index([userId])
  @@map("permissionrequest")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  name                String?
  passwordHash        String?
  role                UserRole             @default(USER)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  capexPermissions    CapexPermission[]
  passwordResetTokens PasswordResetToken[]
  requestsDecided     PermissionRequest[]  @relation("RequestsDecided")
  requestsMade        PermissionRequest[]  @relation("RequestsMade")

  @@map("user")
}

model PlanosDesc {
  tipo               String?
  natureza           String?
  plano_text         String?
  id                 String?
  plano_investimento String  @id @unique
  plano              String?

  @@map("planos_desc")
}

model notification {
  id        String            @id
  title     String
  message   String
  type      notification_type
  read      Boolean           @default(false)
  userId    String?
  createdAt DateTime          @default(now())
  updatedAt DateTime

  @@index([read], map: "Notification_read_idx")
  @@index([userId], map: "Notification_userId_idx")
}

model physicalinput {
  id         Int                 @id @default(autoincrement())
  createdAt  DateTime            @default(now())
  updatedAt  DateTime
  name       String
  risco      physicalinput_risco @default(BAIXO)
  jan        Decimal             @default(0.00) @db.Decimal(18, 2)
  fev        Decimal             @default(0.00) @db.Decimal(18, 2)
  mar        Decimal             @default(0.00) @db.Decimal(18, 2)
  abr        Decimal             @default(0.00) @db.Decimal(18, 2)
  mai        Decimal             @default(0.00) @db.Decimal(18, 2)
  jun        Decimal             @default(0.00) @db.Decimal(18, 2)
  jul        Decimal             @default(0.00) @db.Decimal(18, 2)
  ago        Decimal             @default(0.00) @db.Decimal(18, 2)
  set        Decimal             @default(0.00) @db.Decimal(18, 2)
  out        Decimal             @default(0.00) @db.Decimal(18, 2)
  nov        Decimal             @default(0.00) @db.Decimal(18, 2)
  dez        Decimal             @default(0.00) @db.Decimal(18, 2)
  capexLabel String              @db.VarChar(50)
  capex_web  CapexWeb            @relation(fields: [capexLabel], references: [capex], onDelete: Cascade, map: "PhysicalInput_capexLabel_fkey")

  @@unique([name, capexLabel], map: "PhysicalInput_name_capexLabel_key")
  @@index([capexLabel], map: "PhysicalInput_capexLabel_fkey")
}

enum CapexStatus {
  PENDENTE
  FINALIZADO
  PARCIAL
}

enum PhysicalStatus {
  SIM
  NAO
  PENDENTE
}

enum StatusSolicitacao {
  pendente
  aprovado
  rejeitado
}

enum PermissionRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserRole {
  USER
  EDITOR
  ADMIN
}

enum notification_type {
  GLOBAL
  USER_SPECIFIC
  ADMIN_ONLY
}

enum physicalinput_risco {
  BAIXO
  MEDIO
  ALTO
}
