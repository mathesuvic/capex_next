datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ===== AUTENTICAÇÃO =====

enum Role {
  USER
  EDITOR
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  resetTokens PasswordResetToken[] @relation("UserToReset")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  createdAt DateTime  @default(now())
  usedAt    DateTime?

  user User @relation("UserToReset", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ===== CAPEX / TRANSFERÊNCIAS =====

model CapexWeb {
  ordem   Int?     @default(0)
  plano   String?  @db.VarChar(10)
  capex   String   @db.VarChar(50)
  jan_ano Decimal?
  fev_ano Decimal?
  mar_ano Decimal?
  abr_ano Decimal?
  mai_ano Decimal?
  jun_ano Decimal?
  jul_ano Decimal?
  ago_ano Decimal?
  set_ano Decimal?
  out_ano Decimal?
  nov_ano Decimal?
  dez_ano Decimal?
  meta    Decimal?

  transfersFrom Transfer[] @relation("TransfersFrom")
  transfersTo   Transfer[] @relation("TransfersTo")

  @@id([capex])
  @@map("capex_web")
}

model Transfer {
  id        Int     @id @default(autoincrement())
  amount    Decimal
  fromCapex String  @db.VarChar(50)
  toCapex   String  @db.VarChar(50)

  from CapexWeb @relation("TransfersFrom", fields: [fromCapex], references: [capex], onDelete: Cascade, onUpdate: Cascade)
  to   CapexWeb @relation("TransfersTo", fields: [toCapex], references: [capex], onDelete: Cascade, onUpdate: Cascade)

  @@map("transfers")
}

// ===== SOLICITAÇÃO DE RECURSOS =====

enum StatusSolicitacao {
  pendente
  aprovado
  rejeitado
}

model SolicitacaoRecursos {
  id                 String            @id @default(cuid())
  createdAt          DateTime          @default(now())
  plano_investimento String
  valor_aporte       Decimal           @db.Decimal(18, 2)
  desc_fisico        String
  justificativa      String
  email_solicitante  String
  status_solicitacao StatusSolicitacao @default(pendente)

  jan Decimal @default(0) @db.Decimal(18, 2)
  fev Decimal @default(0) @db.Decimal(18, 2)
  mar Decimal @default(0) @db.Decimal(18, 2)
  abr Decimal @default(0) @db.Decimal(18, 2)
  mai Decimal @default(0) @db.Decimal(18, 2)
  jun Decimal @default(0) @db.Decimal(18, 2)
  jul Decimal @default(0) @db.Decimal(18, 2)
  ago Decimal @default(0) @db.Decimal(18, 2)
  set Decimal @default(0) @db.Decimal(18, 2)
  out Decimal @default(0) @db.Decimal(18, 2)
  nov Decimal @default(0) @db.Decimal(18, 2)
  dez Decimal @default(0) @db.Decimal(18, 2)

  @@map("solicitacao_recursos")
}
