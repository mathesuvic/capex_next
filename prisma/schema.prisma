datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Subplan {
  id            Int            @id @default(autoincrement())
  name          String?
  monthlyValues MonthlyValue[]
}

model MonthlyValue {
  id        Int     @id @default(autoincrement())
  subplanId Int
  month     Int
  type      String
  value     Decimal @db.Decimal(14, 2)

  subplan Subplan @relation(fields: [subplanId], references: [id])

  @@unique([subplanId, month, type])
}
