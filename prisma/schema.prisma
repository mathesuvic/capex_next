// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(USER)
  accounts      Account[]
  sessions      Session[]

  // Relações com PermissionRequest
  requests  PermissionRequest[] @relation("UserRequests")
  decisions PermissionRequest[] @relation("AdminDecisions")
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Status {
  PENDING
  APPROVED
  REJECTED
}

model PermissionRequest {
  id              String   @id @default(cuid())
  userId          String   @db.ObjectId
  capexLabel      String
  reason          String?
  status          Status   @default(PENDING)
  createdAt       DateTime @default(now())
  decidedAt       DateTime?
  decidedByUserId String?  @db.ObjectId

  // Relações nomeadas
  user      User @relation("UserRequests", fields: [userId], references: [id], onDelete: Cascade)
  decidedBy User? @relation("AdminDecisions", fields: [decidedByUserId], references: [id])
}

