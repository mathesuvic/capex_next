// Em prisma/schema.prisma

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Modelo que mapeia a tabela capex_web
model CapexWeb {
  ordem   Int?      @default(0)
  plano   String?   @db.VarChar(10)
  capex   String    @db.VarChar(50)
  jan_ano Decimal?
  fev_ano Decimal?
  mar_ano Decimal?
  abr_ano Decimal?
  mai_ano Decimal?
  jun_ano Decimal?
  jul_ano Decimal?
  ago_ano Decimal?
  set_ano Decimal?
  out_ano Decimal?
  nov_ano Decimal?
  dez_ano Decimal?
  meta Decimal?

  // Relações para transferências
  transfersFrom Transfer[] @relation("TransfersFrom")
  transfersTo   Transfer[] @relation("TransfersTo")

  @@id([capex])
  @@map("capex_web")
}

// Modelo para a tabela de Transferências
model Transfer {
  id        Int      @id @default(autoincrement())
  amount    Decimal
  fromCapex String   @db.VarChar(50)
  toCapex   String   @db.VarChar(50)

  // Relações com a tabela CapexWeb
  from      CapexWeb @relation("TransfersFrom", fields: [fromCapex], references: [capex])
  to        CapexWeb @relation("TransfersTo", fields: [toCapex], references: [capex])

  @@map("transfers")
}


model SolicitacaoRecursos {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())

  plano_investimento String
  valor_aporte       Decimal @db.Decimal(18,2)
  desc_fisico        String
  justificativa      String
  email_solicitante  String

  jan Decimal @db.Decimal(18,2) @default(0)
  fev Decimal @db.Decimal(18,2) @default(0)
  mar Decimal @db.Decimal(18,2) @default(0)
  abr Decimal @db.Decimal(18,2) @default(0)
  mai Decimal @db.Decimal(18,2) @default(0)
  jun Decimal @db.Decimal(18,2) @default(0)
  jul Decimal @db.Decimal(18,2) @default(0)
  ago Decimal @db.Decimal(18,2) @default(0)
  set Decimal @db.Decimal(18,2) @default(0)
  out Decimal @db.Decimal(18,2) @default(0)
  nov Decimal @db.Decimal(18,2) @default(0)
  dez Decimal @db.Decimal(18,2) @default(0)

  @@map("solicitacao_recursos") // usa exatamente este nome da tabela no MySQL
}